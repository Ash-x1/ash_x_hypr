@import "/home/ash/.cache/wal/colors-waybar.css";

/* ===== Semantic mapping من Waybar ===== */
@define-color bg_module alpha(@color0, 0.7);
@define-color border_module alpha(@color4, 0.8);
@define-color text_module @color7;

/* ===== GLOBAL ===== */
* {
    outline: none;
    font-family: "SF Pro Text", "Noto Sans Arabic", "Noto Sans", "JetBrainsMono Nerd Font", sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: @text_module;
    background: transparent;
}

/* ===== CONTROL CENTER ===== */
.control-center {
    background-color: @bg_module;
    border-radius: 14px;
    padding: 6px 10px;
    box-shadow: inset 0 0 10px alpha(@border_module, 0.25);
}

/* ===== NOTIFICATIONS ===== */
.notification {
    background-color: @bg_module;
    border-radius: 14px;
    margin: 4px 3px;
    padding: 10px;
    color: @text_module;
    border: 2px solid @border_module;
    box-shadow: inset 0 0 6px alpha(@border_module, 0.2);
}

/* حالات notifications */
.notification.low,
.notification.normal {
    background-color: alpha(@bg_module, 0.8);
}

.notification.critical {
    background-color: @color1;
    color: @color0;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

@keyframes blink {
    to {
        background-color: @color1;
        color: @color0;
    }
}

/* ===== BUTTONS ===== */
.widget-buttons-grid > flowbox > flowboxchild > button {
    background: @bg_module;
    color: @color7;
    border-radius: 12px;
    min-width: 60px;
    min-height: 30px;
    padding: 6px;
    margin: 0 3px;
    box-shadow: inset 0 0 4px alpha(@border_module, 0.25);
    transition: all 0.3s ease;
}

.widget-buttons-grid > flowbox > flowboxchild > button:hover {
    background: alpha(@color4, 0.2);
    color: @color4;
}

/* ===== VOLUME ===== */
.widget-volume {
    color: @color5;
    font-size: 1.3rem;
}

/* ===== BACKLIGHT ===== */
.widget-backlight {
    color: @color3;
    font-size: 1.1rem;
}

/* ===== MPRIS ===== */
.widget-mpris .widget-mpris-player {
    background-color: alpha(@bg_module, 0.85);
    border-radius: 12px;
    padding: 16px;
    margin: 16px 20px;
    box-shadow: inset 0 0 8px alpha(@border_module, 0.25);
}

.widget-mpris-title {
    color: @color6;
    font-weight: bold;
    font-size: 1.2rem;
}

.widget-mpris-subtitle {
    color: @color4;
    font-size: 1rem;
}

/* ===== CLOCK / SWAYNC ===== */
#clock {
    background-color: @bg_module;
    color: @color7;
    border: 2px solid @border_module;
    border-radius: 14px;
    padding: 4px 12px;
    box-shadow: inset 0 0 10px alpha(@border_module, 0.25);
}

#custom-swaync {
    background-color: @bg_module;
    color: @color3; /* نفس لون Waybar مثال: @color3 */
    border: 2px solid @border_module;
    border-radius: 14px;
    padding: 4px 12px;
    transition: all 0.3s ease;
}

#custom-swaync:hover {
    background-color: alpha(@color3, 0.2);
}

/* ===== BATTERY ===== */
#battery {
    background-color: @bg_module;
    color: @color7;
    border-radius: 14px;
    padding: 2px 10px;
    border: 2px solid @border_module;
}

#battery.charging {
    color: @color2;
}

#battery.warning:not(.charging) {
    color: @color3;
}

#battery.critical:not(.charging) {
    color: @color1;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

/* ===== WORKSPACES ===== */
#workspaces button {
    background-color: transparent;
    color: @color4;
    border-radius: 8px;
    padding: 3px 6px;
    margin: 0 3px;
    transition: all 0.3s ease-in-out;
}

#workspaces button.active {
    background-color: @color4;
    color: @color0;
    min-width: 50px;
}

#workspaces button.urgent {
    background-color: @color1;
    color: @color0;
}

#workspaces button:hover {
    background-color: alpha(@color4, 0.12);
    color: @color4;
    border-radius: 16px;
}

